{
  "name": "T4_mixed_load_compute",
  "category": "T4_register_scheduling",
  "kernel": "mixed_load_compute",
  "gridDim": [
    2048,
    1,
    1
  ],
  "blockDim": [
    256,
    1,
    1
  ],
  "dynamic_smem_bytes": 0,
  "params": [
    {
      "name": "param_a",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "a"
    },
    {
      "name": "param_b",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "b"
    },
    {
      "name": "param_c",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "c"
    },
    {
      "name": "param_d",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "d"
    },
    {
      "name": "param_out",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "out"
    },
    {
      "name": "param_n",
      "type": "u32",
      "kind": "value",
      "value": 524288
    }
  ],
  "buffers": {
    "a": {
      "dtype": "f32",
      "numel": 524288,
      "init": "rand_uniform",
      "seed": 8
    },
    "b": {
      "dtype": "f32",
      "numel": 524288,
      "init": "rand_uniform",
      "seed": 9
    },
    "c": {
      "dtype": "f32",
      "numel": 524288,
      "init": "rand_uniform",
      "seed": 10
    },
    "d": {
      "dtype": "f32",
      "numel": 524288,
      "init": "rand_uniform",
      "seed": 11
    },
    "out": {
      "dtype": "f32",
      "numel": 524288,
      "init": "zero",
      "output": true
    }
  },
  "check": {
    "type": "elementwise",
    "formula": "out[i] = (a[i] + b[i]) * (c[i] - d[i]) + (a[i] * c[i]) * (b[i] + d[i])",
    "output": "out",
    "atol": 1e-05,
    "rtol": 1e-05
  }
}