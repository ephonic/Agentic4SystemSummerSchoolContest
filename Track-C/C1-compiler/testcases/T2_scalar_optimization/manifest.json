{
  "name": "T2_repeated_expression",
  "category": "T2_scalar_optimization",
  "kernel": "repeated_expression",
  "gridDim": [
    2048,
    1,
    1
  ],
  "blockDim": [
    256,
    1,
    1
  ],
  "dynamic_smem_bytes": 0,
  "params": [
    {
      "name": "param_x",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "x"
    },
    {
      "name": "param_y",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "y"
    },
    {
      "name": "param_out",
      "type": "u64",
      "kind": "gmem_ptr",
      "buffer": "out"
    },
    {
      "name": "param_n",
      "type": "u32",
      "kind": "value",
      "value": 524288
    }
  ],
  "buffers": {
    "x": {
      "dtype": "f32",
      "numel": 524288,
      "init": "rand_uniform",
      "seed": 3
    },
    "y": {
      "dtype": "f32",
      "numel": 524288,
      "init": "rand_uniform",
      "seed": 4
    },
    "out": {
      "dtype": "f32",
      "numel": 524288,
      "init": "zero",
      "output": true
    }
  },
  "check": {
    "type": "elementwise",
    "formula": "out[i] = (x[i] + y[i]) * (x[i] + y[i]) + x[i]",
    "output": "out",
    "atol": 1e-05,
    "rtol": 1e-05
  }
}