#!/usr/bin/env bash

# Public, relocatable defaults. Tool names are resolved from PATH; callers may
# override them with absolute paths before sourcing this file.
PPA_FLOW_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

YOSYS="${YOSYS:-yosys}"
OPENSTA="${OPENSTA:-sta}"
ASAP7_LIB_DIR="${ASAP7_LIB_DIR:-$PPA_FLOW_ROOT/lib/asap7sc7p5t_28/LIB/NLDM}"
ASAP7_SRAM_ROOT="${ASAP7_SRAM_ROOT:-$PPA_FLOW_ROOT/lib/asap7_sram_0p0}"

PPA_TOP="${PPA_TOP:-aec_eval_top}"
PPA_FILELIST="${PPA_FILELIST:-rtl/files.f}"
PPA_CLOCK_PORT="${PPA_CLOCK_PORT:-clk}"
PPA_RESET_PORT="${PPA_RESET_PORT:-rst_n}"
PPA_RESET_STYLE="${PPA_RESET_STYLE:-async}"
PPA_BUILD_DIR="${PPA_BUILD_DIR:-build/ppa-flow}"

PPA_ABC_DELAY_PS="${PPA_ABC_DELAY_PS:-1000}"
PPA_UNCERTAINTY_RATIO="${PPA_UNCERTAINTY_RATIO:-0.05}"
PPA_IO_DELAY_RATIO="${PPA_IO_DELAY_RATIO:-0.10}"
PPA_INPUT_DELAY_MIN_NS="${PPA_INPUT_DELAY_MIN_NS:-0.050}"
PPA_INPUT_TRANSITION_NS="${PPA_INPUT_TRANSITION_NS:-0.010}"
PPA_OUTPUT_LOAD_FF="${PPA_OUTPUT_LOAD_FF:-1.0}"
PPA_MIN_PERIOD_NS="${PPA_MIN_PERIOD_NS:-0.050}"
PPA_MAX_PERIOD_NS="${PPA_MAX_PERIOD_NS:-1000.000}"
PPA_PERIOD_STEP_NS="${PPA_PERIOD_STEP_NS:-0.001}"

export YOSYS OPENSTA ASAP7_LIB_DIR ASAP7_SRAM_ROOT
export PPA_TOP PPA_FILELIST PPA_CLOCK_PORT PPA_RESET_PORT PPA_RESET_STYLE PPA_BUILD_DIR
export PPA_ABC_DELAY_PS PPA_UNCERTAINTY_RATIO PPA_IO_DELAY_RATIO
export PPA_INPUT_DELAY_MIN_NS PPA_INPUT_TRANSITION_NS PPA_OUTPUT_LOAD_FF
export PPA_MIN_PERIOD_NS PPA_MAX_PERIOD_NS PPA_PERIOD_STEP_NS
